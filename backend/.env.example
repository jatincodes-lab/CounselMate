# CounselMate backend environment template
# Copy this file to backend/.env for local use, or add these values in Render Environment.

ASPNETCORE_ENVIRONMENT=Production
DefaultTenantSlug=demo-academy

# PostgreSQL / Neon
# Use your real Neon connection string in Render or local backend/.env.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require

# CORS
# Replace with your deployed frontend URL after Vercel deployment.
Cors__AllowedOrigins__0=http://localhost:5173

# Cloudinary document uploads
Cloudinary__CloudName=
Cloudinary__ApiKey=
Cloudinary__ApiSecret=
Cloudinary__FolderRoot=counselmate
Cloudinary__DeliveryType=upload

# Automation / notifications
Automation__ReminderCron=*/5 * * * *
Automation__ExternalChannelsEnabled=false
